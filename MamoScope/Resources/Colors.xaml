<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    
        <SolidColorBrush x:Key="PrimaryBrush"       Color="#1E5AA8"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush"   Color="#154277"/>
        <SolidColorBrush x:Key="PrimarylightBrush"  Color="#E8F1FB"/>

        <SolidColorBrush x:Key="BackgroundBrush"    Color="#F5F7FA"/>
        <SolidColorBrush x:Key="SurfaceBrush"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush"        Color="#D9E2EC"/>

        <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#1A2B3C"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5C7080"/>

        <SolidColorBrush x:Key="SuccessBrush"       Color="#2E7D32"/>
        <SolidColorBrush x:Key="ErrorBrush"         Color="#C62828"/>
    </ResourceDictionary>