<UserControl x:Class="MamoScope.Views.TestRecordsView"
             xmlns:vms="clr-namespace:MamoScope.ViewModels"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MamoScope.Views"
             mc:Ignorable="d" 
             d:Height="650" Width="900" MinHeight="600" MinWidth="850">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="32"
                MaxWidth="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Motor Sürücü Testi" Style="{StaticResource PageTitle}" Margin="0,0,0,24"/>
                <TextBlock Text="Seri Numarası" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding SerialNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                <TextBlock Text="Voltaj Değeri" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding VoltajDegeri, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                
                <TextBlock Text="Tarih" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Tarih, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,20"/>

               
                <TextBlock Text="{Binding TestSonucu}" FontSize="18" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryBrush}" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Geçmiş Testler" 
                            Command="{Binding GecmisKayitlariAcCommand}"
                            Style="{StaticResource SecondaryButton}" Height="44"/>

                    <Button Grid.Column="2" Content="Test Et" 
                            Command="{Binding VoltajTestveKaydetCommand}"
                            Style="{StaticResource PrimaryButton}" Height="44"/>
                </Grid>

                <Button Content="Test Verisi Simüle Et" 
                        Command="{Binding TestVerisiSimuleEtCommand}" 
                        Style="{StaticResource SecondaryButton}" Height="40"
                        HorizontalAlignment="Stretch"/>


            </StackPanel>
        </Border>

        <Grid Background="#99FFFFFF" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="10" 
                             Foreground="{StaticResource PrimaryBrush}" Background="LightGray"/>
                <TextBlock Text="Geçmiş Kayıtlar Hazırlanıyor..." 
                           HorizontalAlignment="Center" Margin="0,10,0,0" 
                           FontSize="14" FontWeight="SemiBold" 
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <Grid Background="#CC000000" 
      Visibility="{Binding IsResultDialogOpen, Converter={StaticResource BoolToVis}}">

            <Border Background="{StaticResource SurfaceBrush}"
            Width="590" Height="200"
            CornerRadius="15"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="24">

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Test Sonucu" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ResultMessage}" 
                       FontSize="16" 
                       HorizontalAlignment="Center" 
                       TextAlignment="Center" 
                       Margin="0,0,0,20"/>

                    <Button Content="Tamam" 
                    Command="{Binding CloseResultDialogCommand}" 
                    Width="100" Height="35"
                    Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>