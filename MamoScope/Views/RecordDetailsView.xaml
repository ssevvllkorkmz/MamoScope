<UserControl x:Class="MamoScope.Views.RecordDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MamoScope"
             mc:Ignorable="d" 
             d:Height="650" Width="900" MinHeight="600" MinWidth="850">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">

        <Border Background="{StaticResource SurfaceBrush}" 
                CornerRadius="12" 
                Margin="30" 
                Padding="30"
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Test Detay Bilgileri" 
                           Style="{StaticResource PageTitle}" 
                           Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1" VerticalAlignment="Top">

                    <TextBlock Text="Seri Numarası" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditableRecord.SerialNumber}" 
                             Style="{StaticResource ModernTextBox}" 
                             Margin="0,0,0,20"/>

                    <TextBlock Text="Voltaj Değeri" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding VoltajDegeriText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}"/>

                    <TextBlock Text="Test Tarihi" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditableRecord.TestDate}" 
                             Style="{StaticResource ModernTextBox}" 
                             IsReadOnly="True" 
                             Margin="0,0,0,20"/>

                    <TextBlock Text="Sonuç" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditableRecord.IsPassed, Converter={StaticResource BoolToResultConverter}}" 
                             Style="{StaticResource ModernTextBox}" 
                             IsReadOnly="True" 
                             Margin="0,0,0,20"/>
                </StackPanel>

                <Button Grid.Row="2" 
                        Content="Geri Dön" 
                        Style="{StaticResource SecondaryButton}" 
                        Command="{Binding GoBackCommand}" 
                        Width="120" HorizontalAlignment="Left"/>

                <Button Grid.Row="2" 
                        Content="Değişiklikleri Kaydet" 
                        Style="{StaticResource PrimaryButton}" 
                        Command="{Binding SaveChangesCommand}" 
                        Width="160" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Grid Background="#CC000000" 
              Visibility="{Binding IsResultDialogOpen, Converter={StaticResource BoolToVis}}">

            <Border Background="{StaticResource SurfaceBrush}"
                    Width="350" Height="200"
                    CornerRadius="15"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="20">

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Uyarı" FontSize="20" FontWeight="Bold" 
                               Foreground="{StaticResource ErrorBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ResultMessage}" 
                               FontSize="16" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center" 
                               Margin="0,0,0,20"/>

                    <Button Content="Tamam" 
                            Command="{Binding CloseResultDialogCommand}" 
                            Width="100" Height="35"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>